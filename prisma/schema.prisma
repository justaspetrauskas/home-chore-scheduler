// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  MEMBER
  EVENT_MANAGER
}

enum DistributionMode {
  random
  balanced
}

enum RecurrenceRule {
  none
  weekly
  biweekly
  monthly
}

enum CleaningEventStatus {
  draft
  scheduled
  in_progress
  completed
  canceled
}

enum TaskAssignmentStatus {
  scheduled
  completed
  post_due
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())

  defaultHouseholdId String?
  defaultHousehold   Household? @relation(fields: [defaultHouseholdId], references: [id])

  memberships     HouseholdMember[]
  taskAssignments TaskAssignment[]
  choresCreated   Chore[]
  telegramAccount TelegramAccount?
  cleaningEventsCreated CleaningEvent[] @relation("CleaningEventCreator")
  cleaningEventParticipations CleaningEventParticipant[]
}

model Household {
  id        String   @id @default(uuid())
  name      String
  ownerId   String
  createdAt DateTime @default(now())

  defaultUsers User[]

  members HouseholdMember[]
  rooms   Room[]
  events  CleaningEvent[]
  invitations Invitation[]
}

model HouseholdMember {
  id          String    @id @default(uuid())
  userId      String
  householdId String
  role        Role
  user        User      @relation(fields: [userId], references: [id])
  household   Household @relation(fields: [householdId], references: [id])

  @@unique([userId, householdId])
}

model TelegramAccount {
  id              String   @id @default(uuid())
  userId          String   @unique
  telegramUserId  String
  telegramChatId  String
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Room {
  id          String           @id @default(uuid())
  name        String
  householdId String
  household   Household        @relation(fields: [householdId], references: [id])
  createdById String
  createdAt   DateTime         @default(now())
  tasks       TaskAssignment[]
  chores      Chore[]

  roomTypeId   String?
  roomType     RoomType? @relation(fields: [roomTypeId], references: [id])
}

model RoomType {
  id        String   @id @default(cuid())
  key       String   @unique // "bedroom", "kitchen", etc.
  label     String   // "Bedroom"
  isDefault Boolean  @default(true)
  createdAt DateTime @default(now())
  rooms     Room[]
}

// Suggested keys for RoomType:
// "bedroom", "living_room", "kitchen", "bathroom", "dining_room", "office", "garage", "laundry_room", "storage", "balcony", "hallway", "other"

model Chore {
  id          String  @id @default(uuid())
  title       String
  description String?
  points      Int

  // optional reference to a room/area
  roomId String?
  room   Room?   @relation(fields: [roomId], references: [id])

  createdById String
  createdBy   User             @relation(fields: [createdById], references: [id])
  createdAt   DateTime         @default(now())
  assignments TaskAssignment[]
}

model CleaningEvent {
  id                 String              @id @default(uuid())
  householdId        String
  household          Household           @relation(fields: [householdId], references: [id])
  name               String
  eventDate          DateTime
  notificationDate   DateTime
  distributionMode   DistributionMode    @default(balanced)
  recurrenceRule     RecurrenceRule      @default(none)
  notifyParticipants Boolean             @default(true)
  status             CleaningEventStatus @default(scheduled)
  createdByUserId    String
  createdByUser      User                @relation("CleaningEventCreator", fields: [createdByUserId], references: [id])
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  tasks              TaskAssignment[]
  participants       CleaningEventParticipant[]
}

model CleaningEventParticipant {
  id      String        @id @default(uuid())
  eventId String
  userId  String
  event   CleaningEvent @relation(fields: [eventId], references: [id])
  user    User          @relation(fields: [userId], references: [id])

  @@unique([eventId, userId])
}

model TaskAssignment {
  id           String               @id @default(uuid())
  eventId      String
  roomId       String
  choreId      String?
  assignedToId String?
  date         DateTime
  status       TaskAssignmentStatus @default(scheduled)
  completedAt  DateTime?
  event        CleaningEvent        @relation(fields: [eventId], references: [id])
  room         Room                 @relation(fields: [roomId], references: [id])
  chore        Chore?               @relation(fields: [choreId], references: [id])
  assignedTo   User?                @relation(fields: [assignedToId], references: [id])
}

model Invitation {
  id          String   @id @default(uuid())
  householdId String
  email       String
  token       String   @unique
  used        Boolean  @default(false)
  createdAt   DateTime @default(now())
  expiresAt   DateTime

  household Household @relation(fields: [householdId], references: [id])
}
